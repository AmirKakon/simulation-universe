<!--
  Desk pickup scene: A Panda arm mounted on a desk with manipulable objects.
  Used as the first SimVerse demo environment.
-->
<mujoco model="desk_pickup">
  <compiler angle="radian" autolimits="true"/>

  <option timestep="0.002" gravity="0 0 -9.81" integrator="implicit">
    <flag multiccd="enable"/>
  </option>

  <default>
    <joint damping="1.0" armature="0.1"/>
    <geom condim="4" friction="1 0.5 0.01" solref="0.02 1"/>
    <position kp="100" kv="20"/>
    <default class="visual">
      <geom group="1" contype="0" conaffinity="0"/>
    </default>
    <default class="collision">
      <geom group="2"/>
    </default>
  </default>

  <asset>
    <texture name="texplane" type="2d" builtin="checker" rgb1="0.25 0.25 0.3" rgb2="0.3 0.3 0.35" width="512" height="512"/>
    <material name="matplane" texture="texplane" texrepeat="4 4" reflectance="0.1"/>
    <material name="table_wood" rgba="0.65 0.45 0.3 1" specular="0.3" shininess="0.3"/>
    <material name="metal" rgba="0.7 0.7 0.7 1" specular="0.8" shininess="0.8"/>
    <material name="dark_metal" rgba="0.3 0.3 0.3 1" specular="0.6" shininess="0.6"/>
    <material name="gripper_mat" rgba="0.5 0.5 0.5 1"/>
    <material name="red_obj" rgba="0.9 0.2 0.2 1" specular="0.5"/>
    <material name="green_obj" rgba="0.2 0.8 0.2 1" specular="0.5"/>
    <material name="blue_obj" rgba="0.2 0.3 0.9 1" specular="0.5"/>
  </asset>

  <worldbody>
    <!-- Ground plane -->
    <geom name="floor" type="plane" size="2 2 0.1" material="matplane"/>
    <light name="top_light" pos="0 0 2.5" dir="0 0 -1" diffuse="0.8 0.8 0.8" specular="0.3 0.3 0.3"/>
    <light name="front_light" pos="1 1 1.5" dir="-0.5 -0.5 -0.5" diffuse="0.5 0.5 0.5"/>

    <!-- Desk -->
    <body name="desk" pos="0.5 0 0">
      <!-- Table top -->
      <geom name="table_top" type="box" size="0.4 0.5 0.02" pos="0 0 0.75" material="table_wood" mass="50"/>
      <!-- Legs -->
      <geom name="leg1" type="cylinder" fromto="-0.35 -0.45 0 -0.35 -0.45 0.73" size="0.025" material="dark_metal"/>
      <geom name="leg2" type="cylinder" fromto="0.35 -0.45 0 0.35 -0.45 0.73" size="0.025" material="dark_metal"/>
      <geom name="leg3" type="cylinder" fromto="-0.35 0.45 0 -0.35 0.45 0.73" size="0.025" material="dark_metal"/>
      <geom name="leg4" type="cylinder" fromto="0.35 0.45 0 0.35 0.45 0.73" size="0.025" material="dark_metal"/>
    </body>

    <!-- Panda arm mounted at one edge of the desk -->
    <body name="panda_link0" pos="0.1 0 0.77">
      <geom type="cylinder" size="0.06 0.05" pos="0 0 0.025" material="dark_metal" class="visual"/>
      <geom type="cylinder" size="0.06 0.05" pos="0 0 0.025" class="collision"/>

      <body name="panda_link1" pos="0 0 0.333">
        <joint name="joint1" type="hinge" axis="0 0 1" range="-2.8973 2.8973" damping="5.0"/>
        <geom type="capsule" fromto="0 0 0 0 0 -0.15" size="0.06" material="metal" class="visual"/>
        <geom type="capsule" fromto="0 0 0 0 0 -0.15" size="0.06" class="collision"/>

        <body name="panda_link2" pos="0 0 0" quat="0.707107 -0.707107 0 0">
          <joint name="joint2" type="hinge" axis="0 0 1" range="-1.7628 1.7628" damping="5.0"/>
          <geom type="capsule" fromto="0 0 0 0 -0.316 0" size="0.06" material="metal" class="visual"/>
          <geom type="capsule" fromto="0 0 0 0 -0.316 0" size="0.06" class="collision"/>

          <body name="panda_link3" pos="0 -0.316 0" quat="0.707107 0.707107 0 0">
            <joint name="joint3" type="hinge" axis="0 0 1" range="-2.8973 2.8973" damping="5.0"/>
            <geom type="capsule" fromto="0 0 0 0.0825 0 0" size="0.05" material="metal" class="visual"/>
            <geom type="capsule" fromto="0 0 0 0.0825 0 0" size="0.05" class="collision"/>

            <body name="panda_link4" pos="0.0825 0 0" quat="0.707107 0.707107 0 0">
              <joint name="joint4" type="hinge" axis="0 0 1" range="-3.0718 -0.0698" damping="5.0"/>
              <geom type="capsule" fromto="0 0 0 -0.0825 0.384 0" size="0.05" material="metal" class="visual"/>
              <geom type="capsule" fromto="0 0 0 -0.0825 0.384 0" size="0.05" class="collision"/>

              <body name="panda_link5" pos="-0.0825 0.384 0" quat="0.707107 -0.707107 0 0">
                <joint name="joint5" type="hinge" axis="0 0 1" range="-2.8973 2.8973" damping="3.0"/>
                <geom type="capsule" fromto="0 0 0 0 0 -0.1" size="0.04" material="dark_metal" class="visual"/>
                <geom type="capsule" fromto="0 0 0 0 0 -0.1" size="0.04" class="collision"/>

                <body name="panda_link6" pos="0 0 0" quat="0.707107 0.707107 0 0">
                  <joint name="joint6" type="hinge" axis="0 0 1" range="-0.0175 3.7525" damping="3.0"/>
                  <geom type="capsule" fromto="0 0 0 0.088 0 0" size="0.04" material="metal" class="visual"/>
                  <geom type="capsule" fromto="0 0 0 0.088 0 0" size="0.04" class="collision"/>

                  <body name="panda_link7" pos="0.088 0 0" quat="0.707107 0.707107 0 0">
                    <joint name="joint7" type="hinge" axis="0 0 1" range="-2.8973 2.8973" damping="1.0"/>
                    <geom type="cylinder" size="0.04 0.02" pos="0 0 0.05" material="dark_metal" class="visual"/>
                    <geom type="cylinder" size="0.04 0.02" pos="0 0 0.05" class="collision"/>

                    <site name="end_effector" pos="0 0 0.1034" size="0.01" rgba="1 0 0 1"/>

                    <body name="panda_hand" pos="0 0 0.1034" quat="0.924 0 0 -0.383">
                      <geom type="box" size="0.015 0.04 0.03" pos="0 0 0.04" material="gripper_mat" class="visual"/>
                      <geom type="box" size="0.015 0.04 0.03" pos="0 0 0.04" class="collision"/>

                      <body name="panda_leftfinger" pos="0 0 0.0584">
                        <joint name="finger_joint1" type="slide" axis="0 1 0" range="0 0.04" damping="10"/>
                        <geom type="box" size="0.01 0.005 0.03" pos="0 0.015 0.02" material="gripper_mat" class="visual"/>
                        <geom type="box" size="0.01 0.005 0.03" pos="0 0.015 0.02" class="collision"/>
                      </body>

                      <body name="panda_rightfinger" pos="0 0 0.0584">
                        <joint name="finger_joint2" type="slide" axis="0 -1 0" range="0 0.04" damping="10"/>
                        <geom type="box" size="0.01 0.005 0.03" pos="0 -0.015 0.02" material="gripper_mat" class="visual"/>
                        <geom type="box" size="0.01 0.005 0.03" pos="0 -0.015 0.02" class="collision"/>
                      </body>
                    </body>
                  </body>
                </body>
              </body>
            </body>
          </body>
        </body>
      </body>
    </body>

    <!-- Manipulable objects on the desk -->
    <body name="red_cube" pos="0.5 0.1 0.8">
      <freejoint name="red_cube_joint"/>
      <geom name="red_cube_geom" type="box" size="0.025 0.025 0.025" material="red_obj" mass="0.1"/>
    </body>

    <body name="green_cylinder" pos="0.6 -0.1 0.8">
      <freejoint name="green_cylinder_joint"/>
      <geom name="green_cylinder_geom" type="cylinder" size="0.02 0.03" material="green_obj" mass="0.08"/>
    </body>

    <body name="blue_sphere" pos="0.5 -0.15 0.8">
      <freejoint name="blue_sphere_joint"/>
      <geom name="blue_sphere_geom" type="sphere" size="0.025" material="blue_obj" mass="0.05"/>
    </body>

    <!-- Camera for overhead view -->
    <camera name="overhead" pos="0.5 0 1.8" quat="0.707 0.707 0 0" fovy="60"/>
    <camera name="side" pos="1.5 0 1.2" quat="0.5 0.5 -0.5 -0.5" fovy="60"/>
    <camera name="front" pos="0.5 -1.2 1.0" xyaxes="1 0 0 0 0.5 0.866" fovy="60"/>
  </worldbody>

  <actuator>
    <position name="actuator1" joint="joint1" kp="4500"/>
    <position name="actuator2" joint="joint2" kp="4500"/>
    <position name="actuator3" joint="joint3" kp="3500"/>
    <position name="actuator4" joint="joint4" kp="3500"/>
    <position name="actuator5" joint="joint5" kp="2000"/>
    <position name="actuator6" joint="joint6" kp="2000"/>
    <position name="actuator7" joint="joint7" kp="2000"/>
    <position name="actuator_finger1" joint="finger_joint1" kp="1000"/>
    <position name="actuator_finger2" joint="finger_joint2" kp="1000"/>
  </actuator>

  <sensor>
    <jointpos name="joint1_pos" joint="joint1"/>
    <jointpos name="joint2_pos" joint="joint2"/>
    <jointpos name="joint3_pos" joint="joint3"/>
    <jointpos name="joint4_pos" joint="joint4"/>
    <jointpos name="joint5_pos" joint="joint5"/>
    <jointpos name="joint6_pos" joint="joint6"/>
    <jointpos name="joint7_pos" joint="joint7"/>
  </sensor>
</mujoco>
